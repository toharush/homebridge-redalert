{
  "displayName": "Red Alert",
  "name": "homebridge-redalert",
  "version": "3.0.0",
  "author": "toharush",
  "description": "Homebridge plugin for Israeli Red Alert (Pikud HaOref) notifications via HomeKit motion sensors",
  "license": "Apache-2.0",
  "engines": {
    "node": "^18.20.4 || ^20.15.1 || ^22 || ^24 || ^25",
    "homebridge": "^1.6.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/ --max-warnings=20",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "test": "tsx --test src/**/*.spec.ts",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "homebridge-plugin",
    "red-alert",
    "pikud-haoref",
    "israel",
    "homekit",
    "alerts"
  ],
  "dependencies": {
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "homebridge": "^1.11.2",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
