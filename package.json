{
  "displayName": "Red Alert",
  "name": "@toharush/homebridge-redalert",
  "version": "1.3.9",
  "author": "toharush",
  "description": "Homebridge plugin for Israeli Red Alert (Pikud HaOref) notifications via HomeKit motion sensors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toharush/homebridge-redalert.git"
  },
  "bugs": {
    "url": "https://github.com/toharush/homebridge-redalert/issues"
  },
  "homepage": "https://github.com/toharush/homebridge-redalert#readme",
  "engines": {
    "node": "^20.15.1 || ^22 || ^24 || ^25",
    "homebridge": "^1.6.0 || ^2.0.0-beta.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "config.schema.json",
    "homebridge-ui/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "lint": "eslint src/ --max-warnings=20",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc && npm run copy-data",
    "copy-data": "mkdir -p dist/data && cp src/data/cities.json dist/data/",
    "test": "tsx --test src/**/*.spec.ts",
    "prepublishOnly": "npm run lint && npm run build",
    "first-publish": "npm publish --access public"
  },
  "keywords": [
    "homebridge-plugin",
    "red-alert",
    "צבע אדום",
    "pikud-haoref",
    "פיקוד העורף",
    "israel",
    "homekit",
    "alerts",
    "rocket-alert",
    "missile-alert",
    "air-raid",
    "siren",
    "security",
    "smart-home",
    "home-automation",
    "homebridge-redalert",
    "homebridge-plugin"
  ],
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^1.0.0",
    "lodash": "^4.17.23"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "homebridge": "^1.11.2",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
